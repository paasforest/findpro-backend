# Server
PORT=5000
NODE_ENV=production

# Database (Hetzner PostgreSQL)
DATABASE_URL=postgresql://findpro_user:PASSWORD@YOUR_HETZNER_IP:5432/findpro_db

# JWT
JWT_SECRET=your_very_long_random_secret_here
JWT_EXPIRES_IN=7d

# Hetzner Object Storage (S3-compatible)
HETZNER_STORAGE_ENDPOINT=https://YOUR-BUCKET.your-hetzner-region.your-hetzner-storage.com
HETZNER_ACCESS_KEY_ID=your_access_key
HETZNER_SECRET_ACCESS_KEY=your_secret_key
HETZNER_BUCKET_NAME=findpro-media
HETZNER_REGION=eu-central-1
STORAGE_BASE_URL=https://findpro-media.your-hetzner-storage.com

# Email – Resend (https://resend.com). Domain mail.findpro.co.za must be verified.
# Option A (recommended): Resend HTTP API
RESEND_API_KEY=re_your_actual_key
# Optional display name for From (overrides EMAIL_FROM for Resend SDK sends)
# RESEND_FROM=FindPro <noreply@mail.findpro.co.za>
EMAIL_FROM=noreply@mail.findpro.co.za

# Option B: Resend SMTP (if you do not set RESEND_API_KEY, use this instead — same API key as SMTP_PASS)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_your_actual_api_key

# Admin (used by startup bootstrap + seed; must match for login)
ADMIN_EMAIL=admin@findpro.co.za
ADMIN_PASSWORD=ChangeMe123!

# Featured listing price (ZAR per month)
FEATURED_AMOUNT=79

# Bank details (Featured listing – EFT)
BANK_NAME=ABSA BANK
BANK_BRANCH_CODE=632005
BANK_ACCOUNT_NUMBER=4115223741
BANK_ACCOUNT_NAME=FindPro

# PayFast (future)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# Frontend URL (for CORS). Comma-separated for multiple (e.g. https://findpro.co.za,https://www.findpro.co.za)
FRONTEND_URL=https://findpro.co.za

# Unclaimed listings (system user email; seed creates this user)
UNCLAIMED_EMAIL=unclaimed@findpro.co.za
