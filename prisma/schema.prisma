generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  business_owner
  user
}

enum ListingPlan {
  free
  featured
  premium
}

enum ListingStatus {
  active
  pending
  expired
  suspended
}

enum BusinessStatus {
  pending
  active
  suspended
}

enum MediaType {
  logo
  gallery
  cover
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum BusinessSource {
  manual
  imported
  google
  scraped
}

model User {
  id                         String    @id @default(uuid())
  name                       String
  email                      String    @unique
  phone                      String?
  passwordHash               String
  role                       Role      @default(user)
  emailVerified              Boolean   @default(false)
  emailVerificationToken     String?
  emailVerificationExpiresAt DateTime?
  createdAt                  DateTime  @default(now())
  businesses                 Business[]
  reviews                    Review[]
}

model Category {
  id                  String               @id @default(uuid())
  name                String
  slug                String               @unique
  icon                String
  createdAt           DateTime             @default(now())
  businessCategories  BusinessCategory[]
  services            Service[]            // services often offered in this category (e.g. Electricians → COC, Solar)
}

model City {
  id                    String                @id @default(uuid())
  name                  String
  province              String
  slug                  String                @unique
  createdAt             DateTime              @default(now())
  businesses            Business[]
  businessServiceAreas  BusinessServiceArea[]  // businesses that serve this city
}

model Business {
  id                    String                @id @default(uuid())
  name                  String
  slug                  String                @unique
  description           String
  phone                 String
  whatsapp              String?
  email                 String?
  website               String?
  logoUrl               String?
  coverImage            String?
  address               String?
  cityId                String                // primary/base city
  ownerId               String
  verified              Boolean               @default(false)
  featured              Boolean              @default(false)
  featuredUntil         DateTime?            // when featured period ends; cron sets featured=false when passed
  status                BusinessStatus      @default(pending)
  source                BusinessSource       @default(manual)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  city                  City                 @relation(fields: [cityId], references: [id])
  owner                 User                 @relation(fields: [ownerId], references: [id])
  businessCategories    BusinessCategory[]
  businessServices      BusinessService[]    // services this business offers (required for listing)
  businessServiceAreas  BusinessServiceArea[] // cities/areas this business serves (required for listing)
  listings              Listing[]
  reviews               Review[]
  media                 Media[]
  payments              Payment[]
}

model BusinessCategory {
  id          String    @id @default(uuid())
  businessId  String
  categoryId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id])

  @@unique([businessId, categoryId])
}

// Master list of services (e.g. COC certificates, Solar installation). Enables filter-by-service like other directories.
model Service {
  id                  String           @id @default(uuid())
  name                String
  slug                String           @unique
  categoryId          String?          // optional: scope to category (e.g. Electricians)
  sortOrder           Int              @default(0)
  createdAt           DateTime        @default(now())
  category            Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  businessServices    BusinessService[]
}

// Which services does this business offer? (many-to-many). Required for a valid listing.
model BusinessService {
  id          String    @id @default(uuid())
  businessId  String
  serviceId   String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([businessId, serviceId])
}

// Which cities/areas does this business serve? (many-to-many). Required for a valid listing; at least one.
model BusinessServiceArea {
  id          String    @id @default(uuid())
  businessId  String
  cityId      String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  city        City      @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([businessId, cityId])
}

model Listing {
  id          String        @id @default(uuid())
  businessId  String
  plan        ListingPlan   @default(free)
  price       Float         @default(0)
  expiresAt   DateTime?
  status      ListingStatus @default(pending)
  createdAt   DateTime      @default(now())
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Review {
  id          String   @id @default(uuid())
  businessId  String
  userId      String
  rating      Int
  comment     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
}

model Media {
  id          String    @id @default(uuid())
  businessId  String
  url         String
  type        MediaType
  createdAt   DateTime  @default(now())
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(uuid())
  businessId    String
  amount        Float
  currency      String        @default("ZAR")
  status        PaymentStatus @default(pending)
  paymentMethod String?
  reference     String?       @unique
  proofUrl      String?
  createdAt     DateTime      @default(now())
  business      Business      @relation(fields: [businessId], references: [id])
}
